# Google Analytics 4 measurement ID (optional — enables gtag in production)
VITE_GA_ID=G-XXXXXXXXXX

# Cloudinary unsigned upload (for /dang-bai image attachments)
# Create an unsigned upload preset in Cloudinary Dashboard → Settings → Upload
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# Supabase (browser — safe to expose anon key with RLS enabled)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Supabase server-only (Vercel Edge Functions / server — NEVER prefix with VITE_)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
